# ─────────────────────────────────────────────────────────────────────────────
# Andyria Configuration
# Copy this file to .env and edit as needed.
# All values shown are defaults — only change what you need.
# ─────────────────────────────────────────────────────────────────────────────

# ── Node identity ─────────────────────────────────────────────────────────────
# Unique identifier for this node. Auto-generated if not set.
ANDYRIA_NODE_ID=andyria-node-0
ANDYRIA_PEER_NODE_ID=andyria-node-1

# ── Network ───────────────────────────────────────────────────────────────────
# Port the Andyria HTTP server listens on.
ANDYRIA_PORT=7700

# Comma-separated list of peer node URLs for mesh sync.
# Example: ANDYRIA_PEERS=http://node2.local:7700,http://node3.local:7700
ANDYRIA_PEERS=

# ── Language models ───────────────────────────────────────────────────────────
# Ollama server URL. Use host.docker.internal inside Docker on Mac/Windows.
# On Linux Docker use: http://172.17.0.1:11434
ANDYRIA_OLLAMA_URL=http://host.docker.internal:11434

# Default Ollama model. Run `ollama list` to see available models.
# Recommended: phi3, llama3, mistral, gemma2
ANDYRIA_OLLAMA_MODEL=phi3

# Path to a local GGUF model file (optional — used if Ollama is unavailable).
# Example: ANDYRIA_LOCAL_MODEL_PATH=/models/tinyllama-1.1b-chat-v1.0.Q4_K_M.gguf
ANDYRIA_LOCAL_MODEL_PATH=

# ── Storage ───────────────────────────────────────────────────────────────────
# Data directory for persistent storage (events, memory, agent state).
ANDYRIA_DATA_DIR=/data/andyria

# ── Entropy ───────────────────────────────────────────────────────────────────
# Comma-separated entropy sources. Available: os_urandom, clock_jitter, thermal,
# system_stats, hwrng (Raspberry Pi BCM hardware RNG).
ANDYRIA_ENTROPY_SOURCES=os_urandom,clock_jitter,thermal,system_stats

# Optional periodic entropy sampler (milliseconds). 0 disables background sampling.
ANDYRIA_ENTROPY_SAMPLER_INTERVAL_MS=0

# Mark sampler degraded when active source count drops below this value.
ANDYRIA_ENTROPY_MIN_ACTIVE_SOURCES=1

# Mark sampler unhealthy after this many consecutive degraded/failed samples.
ANDYRIA_ENTROPY_MAX_CONSECUTIVE_DEGRADED=3

# Fail-closed request handling when entropy sampler is unhealthy (1=true, 0=false).
ANDYRIA_ENTROPY_FAIL_CLOSED=0

# ── Deployment class ──────────────────────────────────────────────────────────
# server | edge | dev
# edge = reduced entropy sources, lower memory footprint
ANDYRIA_DEPLOYMENT_CLASS=server

# ── Agent seeding (optional) ──────────────────────────────────────────────────
# Auto-create an agent from a preset on first startup.
# Available presets: general, coder, analyst, researcher, support, writer,
#                    teacher, guardian, mesh-sentinel
# Leave empty to skip (you can always create agents from the UI).
ANDYRIA_SEED_AGENT=

# ── Reasoning & Auto-Learn ────────────────────────────────────────────────────
# Confidence threshold for auto-learn recording (0.0–1.0).
ANDYRIA_LEARN_THRESHOLD=0.80

# Maximum stored auto-learn entries.
ANDYRIA_LEARN_MAX_ENTRIES=15

# ATM maximum think iterations per request.
ANDYRIA_ATM_MAX_ITER=3

# ── API security ──────────────────────────────────────────────────────────────
# Optional static API key. If set, all /v1/* requests require:
#   Authorization: Bearer <key>
# Leave empty to disable authentication (safe for local/trusted networks).
ANDYRIA_API_KEY=

# CORS allowed origins (comma-separated). * = allow all.
ANDYRIA_CORS_ORIGINS=*

# ── Dev / debug ───────────────────────────────────────────────────────────────
# Set to 1 to enable verbose debug logging.
ANDYRIA_DEBUG=0

# Log level: DEBUG | INFO | WARNING | ERROR
ANDYRIA_LOG_LEVEL=INFO
