{
  "tiktok_username": "YOUR_TIKTOK_USERNAME",
  "default_persona": "default",
  "voice": {
    "enabled": true,
    "tri_layer": true,
    "layer_primary": { "rate": 1.0, "pitch": 1.0 },
    "layer_echo":    { "delay_ms": 120, "gain": 0.45 },
    "layer_whisper": { "delay_ms": 280, "gain": 0.2 }
  },
  "llm": {
    "system_prompt": "",
    "max_tokens": 120,
    "max_history": 20,
    "providers": {
      "openai": {
        "enabled":  true,
        "api_key":  "",
        "model":    "gpt-4o-mini"
      },
      "anthropic": {
        "enabled":  true,
        "api_key":  "",
        "model":    "claude-haiku-4-5"
      },
      "gemini": {
        "enabled":  true,
        "api_key":  "",
        "model":    "gemini-1.5-flash"
      },
      "groq": {
        "enabled":  true,
        "api_key":  "",
        "model":    "llama-3.1-8b-instant"
      },
      "openrouter": {
        "enabled":  true,
        "api_key":  "",
        "model":    "meta-llama/llama-3.2-3b-instruct:free"
      },
      "ollama": {
        "enabled":   true,
        "base_url":  "http://localhost:11434",
        "model":     "llama3.2"
      },
      "huggingface": {
        "enabled":  true,
        "api_key":  "",
        "model":    "HuggingFaceH4/zephyr-7b-beta"
      }
    }
  },
  "revenue": {
    "auto_drop_on_gift": true,
    "gift_threshold_coins": 100,
    "shop_link": "https://shop.example.com",
    "affiliate_tag": "jetstreamin"
  },
  "engagement": {
    "greetRateLimitMs": 90000,
    "returningPriorityVisits": 2,
    "highValueCoinsThreshold": 200,
    "spamWindowMs": 10000,
    "spamMaxMessages": 6,
    "duplicateMessageWindowMs": 8000
  },
  "commands": {
    "permissions": {
      "/help": "viewer",
      "/stats": "viewer",
      "/game": "viewer",
      "/revenue": "viewer",
      "/shoutout": "mod",
      "/drop": "mod",
      "/reset": "mod",
      "/persona": "admin",
      "/skill": "admin",
      "/dag": "admin",
      "/conversational:on": "mod",
      "/conversational:off": "mod",
      "/conversational:toggle": "mod",
      "/conversational:status": "viewer"
    }
  },
  "runtime": {
    "queuePriorities": {
      "gift": 100,
      "command": 80,
      "member": 60,
      "follow": 50,
      "share": 40,
      "like": 35,
      "chat": 20
    },
    "reconnect": {
      "enabled": true,
      "baseDelayMs": 1500,
      "maxDelayMs": 30000
    },
    "metricsLogIntervalMs": 30000
  },
  "obs": {
    "enabled": false,
    "websocket_url": "ws://localhost:4455",
    "password": ""
  },
  "dry_run": false,
  "log_level": "info",
  "conversational": {
    "default": false,
    "rateLimitMs": 8000,
    "globalRateLimitMs": 500
  },
  "logging": {
    "ndjson": {
      "enabled": true,
      "dir": "./logs",
      "maxFileMB": 50
    }
  }
}
